{
  "engine": "webAudioProcedural",
  "noExternalAudioFiles": true,
  "defaults": { "master": 0.8, "bgm": 0.5, "sfx": 0.8, "muted": false },
  "bgm": {
    "islandDay":   { "tempo": 82, "scale": "majorPentatonic", "root": 220, "mood": "warm",      "pattern": [0, 2, 4, 7, 4, 2, 0, 4], "padFreq": 110, "filter": 950 },
    "islandNight": { "tempo": 60, "scale": "majorPentatonic", "root": 196, "mood": "sleepy",     "pattern": [0, 4, 7, 4],             "padFreq": 98,  "filter": 600 },
    "mine":        { "tempo": 70, "scale": "minorPentatonic", "root": 165, "mood": "mysterious", "pattern": [0, 3, 5, 3, 0, -2],      "padFreq": 82,  "filter": 520 },
    "shop":        { "tempo": 96, "scale": "majorPentatonic", "root": 262, "mood": "cheerful",   "pattern": [0, 2, 4, 5, 7, 5, 4, 2], "padFreq": 131, "filter": 1100 }
  },
  "sfx": {
    "tapMove":      { "type": "blip",     "wave": "sine",     "freq": 660,  "dur": 0.07, "vol": 0.4 },
    "chopTree":     { "type": "noiseHit", "noise": "brown",   "freq": 420,  "dur": 0.12, "vol": 0.5 },
    "mineRock":     { "type": "metalHit", "wave": "triangle", "freq": 200,  "dur": 0.11, "vol": 0.5 },
    "harvestCrop":  { "type": "pop",      "wave": "triangle", "freq": 540,  "dur": 0.12, "vol": 0.5 },
    "collectItem":  { "type": "arp",      "wave": "sine",     "freqs": [660, 880],            "dur": 0.13, "vol": 0.45 },
    "sellItem":     { "type": "arp",      "wave": "triangle", "freqs": [660, 880, 1320],      "dur": 0.18, "vol": 0.5 },
    "build":        { "type": "arp",      "wave": "triangle", "freqs": [392, 523, 659],       "dur": 0.3,  "vol": 0.55 },
    "upgrade":      { "type": "arp",      "wave": "triangle", "freqs": [523, 659, 784, 1046], "dur": 0.35, "vol": 0.55 },
    "questDone":    { "type": "arp",      "wave": "triangle", "freqs": [523, 659, 784, 1046], "dur": 0.45, "vol": 0.6 },
    "staminaEmpty": { "type": "sweep",    "wave": "sine",     "from": 360, "to": 150, "dur": 0.42, "vol": 0.5 },
    "sleepStart":   { "type": "sweep",    "wave": "sine",     "from": 300, "to": 150, "dur": 0.7,  "vol": 0.45 },
    "wakeUp":       { "type": "sweep",    "wave": "sine",     "from": 330, "to": 660, "dur": 0.6,  "vol": 0.5 },
    "maxStaminaUp": { "type": "arp",      "wave": "triangle", "freqs": [523, 659, 784, 1046, 1318], "dur": 0.6, "vol": 0.6 },
    "uiOpen":       { "type": "blip",     "wave": "sine",     "freq": 520,  "dur": 0.06, "vol": 0.35 },
    "uiClose":      { "type": "blip",     "wave": "sine",     "freq": 360,  "dur": 0.06, "vol": 0.3 },
    "buttonClick":  { "type": "blip",     "wave": "square",   "freq": 440,  "dur": 0.04, "vol": 0.3 },
    "error":        { "type": "blip",     "wave": "square",   "freq": 180,  "dur": 0.12, "vol": 0.35 }
  }
}
